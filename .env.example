# Cre8Pilot LLM configuration template.
# Real API keys go in .env only.
# .env is private and ignored by git.
# .env.example is only a safe template for teammates.
# If LLM is disabled or keys are missing, Cre8Pilot falls back to mock mode.

CRE8PILOT_LLM_ENABLED=0

CRE8PILOT_PRIMARY_PROVIDER=groq
CRE8PILOT_PRIMARY_API_KEY=put_your_groq_api_key_here
CRE8PILOT_PRIMARY_API_URL=https://api.groq.com/openai/v1/chat/completions
CRE8PILOT_PRIMARY_MODEL=llama-3.1-8b-instant

CRE8PILOT_BACKUP_PROVIDER=openrouter
CRE8PILOT_BACKUP_API_KEY=put_your_openrouter_api_key_here
CRE8PILOT_BACKUP_API_URL=https://openrouter.ai/api/v1/chat/completions
CRE8PILOT_BACKUP_MODEL=meta-llama/llama-3.2-3b-instruct:free

CRE8PILOT_TIMEOUT_SECONDS=12
