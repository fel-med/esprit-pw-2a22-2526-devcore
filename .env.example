# Cre8Pilot LLM configuration template.
# Real API keys go in .env only.
# .env is private and ignored by git.
# .env.example is only a safe template for teammates.
# If LLM is disabled or keys are missing, Cre8Pilot falls back to mock mode.

CRE8PILOT_LLM_ENABLED=

CRE8PILOT_PRIMARY_PROVIDER=groq
CRE8PILOT_PRIMARY_API_KEY=put_your_huggingface_token_here
CRE8PILOT_PRIMARY_API_URL=https://api.groq.com/openai/v1/chat/completions
CRE8PILOT_PRIMARY_MODEL=llama-3.1-8b-instant

CRE8PILOT_BACKUP_PROVIDER=openrouter
CRE8PILOT_BACKUP_API_KEY=put_your_huggingface_token_here
CRE8PILOT_BACKUP_API_URL=https://openrouter.ai/api/v1/chat/completions
CRE8PILOT_BACKUP_MODEL=meta-llama/llama-3.2-3b-instruct:free

CRE8PILOT_TIMEOUT_SECONDS=12

CRE8SHIELD_AI_ENABLED=1
CRE8SHIELD_PROVIDER=groq
CRE8SHIELD_MODEL=openai/gpt-oss-safeguard-20b
CRE8SHIELD_TIMEOUT_SECONDS=10

# Cre8Shield V23.3 — optional Hugging Face SecureBERT2.0-NER (entity extraction only; does not replace rules or Groq safeguard).
CRE8SHIELD_NER_ENABLED=0
CRE8SHIELD_NER_PROVIDER=huggingface
CRE8SHIELD_NER_MODEL=cisco-ai/SecureBERT2.0-NER
CRE8SHIELD_NER_API_URL=https://api-inference.huggingface.co/models/cisco-ai/SecureBERT2.0-NER
CRE8SHIELD_HF_API_KEY=put_your_huggingface_token_here
CRE8SHIELD_NER_TIMEOUT_SECONDS=12