<section class="section ">
  <div class="section__color-wrapper "><header class="section__header container text-container"><h2 class="heading heading--small">Everything about the zenith</h2></header><gallery-list class="gallery">
      <scrollable-content class="gallery__list-wrapper is-scrollable hide-scrollbar">
