    <script>
      (function () {
        function init_rivyo_scroll() {
          var triggers = document.querySelectorAll('.rivyoWidgetTrigger');
          triggers.forEach(function (this_click) {
            if (!this_click.getAttribute('data-rivyo-scroll-init')) {
              this_click.setAttribute('data-rivyo-scroll-init', 'true');

              this_click.addEventListener('click', function (event) {
                event.preventDefault();
                event.stopImmediatePropagation();

                var rivyo_scroll_content = document.querySelector('.wc_review_main_content');
                if (rivyo_scroll_content) {
                  var rivyo_body_offset = document.body.getBoundingClientRect().top + 100;

                  window.scrollTo({
                    top: rivyo_scroll_content.getBoundingClientRect().top - rivyo_body_offset,
                    behavior: 'smooth',
                  });
                }
              });
            }
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init_rivyo_scroll);
        } else {
          init_rivyo_scroll();
        }

        if (window.Shopify && window.Shopify.designMode) {
          document.addEventListener('shopify:section:load', init_rivyo_scroll);
        }
      })();
    </script>
  




