<script>
  window.CPD = window.CPD || {};
  window.CPD.isUpdatingDOM = false;
  
  window.CPD.settings = {"cart":{"container":".page-content","thumbnail":".line-item-table .line-item-table__list .line-item","priceContainer":".line-item__product .price-list","salePrice":".price","compareAtPrice":"s","lineItemPrice":".line-item__price-list-container .price .money","totalPrice":".cart__total-container .money"},"product":{"priceContainer":".product__info","salePrice":".price-list .price .money","compareAtPrice":"s","salePriceClassNames":"money"},"DWS":{"style":{"background":"#ffd202"},"product-row":{"collapse":true}}};
  
  window.CPD.products = window.CPD.products || {};
  window.CPD.shop = {};
  window.CPD.shop.money_format = "\u003cspan class=money\u003e€{{amount_with_comma_separator}}\u003c\/span\u003e";
  window.CPD.customer = {
    id: null,
    email: null,
    tags: null,
    has_discount: false,
  };
  window.CPD.currency = window.Shopify.currency;
  window.CPD.shopify = {
    currency: "EUR",
    isCartPage: function () {
      return location.href.includes('/cart');
    }
  };

  window.CPD.addToCart = function (button) {
    const variantId = button.getAttribute('data-variant-id');
    const quantity = button.getAttribute('data-quantity');


    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        items: [
          {
            quantity: quantity,
            id: variantId
          }
        ]
      })
    })
      .then((response) => response.json())
      .then((data) => {
        window.location.href = '/cart';
      })
      .catch((error) => {
        console.error('Error:', error);
      });
  };
</script>

<style>
  shopify-accelerated-checkout,
  .cart-item__details ul.discounts,
  .cart-recap__amount-saved {
    display: none !important;
  }
</style>
<script>
  /**
   * Keeps window.CPD.cart.totalPrice in sync with the storefront cart (Shopify returns total_price in cents).
   * Primary URL /cart.json; falls back to /cart.js (standard Ajax Cart API).
   */
  function syncCpdCartTotalFromCartJson() {
    if (window.__cpdCartTotalSyncing) return;
    window.__cpdCartTotalSyncing = true;
    window.CPD.cart = window.CPD.cart || {};
    fetch('/cart.json')
      .then(function (r) {
        return r.ok ? r.json() : Promise.reject();
      })
      .catch(function () {
        return fetch('/cart.js').then(function (r) {
          return r.json();
        });
      })
      .then(function (data) {
        if (data && typeof data.total_price === 'number') {
          window.CPD.cart.totalPrice = data.total_price;
          if (typeof updateCheckoutButtons === 'function') {
            updateCheckoutButtons();
          }
        }
      })
      .catch(function () {})
      .finally(function () {
        window.__cpdCartTotalSyncing = false;
      });
  }

  function observeCartMutationsForCpdTotal() {
    try {
      // Only cart *mutations* (add/change/update/clear) — not GET /cart.js or /cart.json, or we loop on our own sync fetches.
      var cartMutationPattern = /\/cart\/(add|change|update|clear)/;
      var po = new PerformanceObserver(function (list) {
        list.getEntries().forEach(function (entry) {
          var t = entry.initiatorType;
          if (t !== 'xmlhttprequest' && t !== 'fetch') return;
          if (!cartMutationPattern.test(entry.name || '')) return;
          syncCpdCartTotalFromCartJson();
        });
      });
      po.observe({ entryTypes: ['resource'] });
    } catch (e) {}
  }

  syncCpdCartTotalFromCartJson();
  observeCartMutationsForCpdTotal();

  function updateCheckoutButtons() {
    document.querySelectorAll('shopify-accelerated-checkout-cart').forEach((el) => {
      el.remove();
    });
    if (!CPD.shopify.isCartPage()) {
      document.querySelectorAll("[name='checkout'], [href*='/checkout'],.button-checkout").forEach((b) => {
        b.type = 'button';
        b.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          e.stopPropagation();
          e.target.disabled = true;
          window.location.href = '/cart';
        });
      });
    } else {
      // Check the current cart total and if it meets the minimum order value
      const minimumOrderValue = (window.CPD.cart?.minimumOrderValue || 0) * 100; // Convert to cents
      const cartTotal = window.CPD.cart?.totalPrice || 0; // Assuming totalPrice is in cents
      const checkoutButtons = document.querySelectorAll('button#cpd-checkout-button, input#cpd-checkout-button');
      checkoutButtons.forEach((checkoutButton) => {
        // Disconnect the observer to prevent infinite loop
        if (window.__checkoutButtonsObserver__) {
          window.__checkoutButtonsObserver__.disconnect();
        }
        if (cartTotal < minimumOrderValue) {
          checkoutButton.disabled = true;
          checkoutButton.classList.add('disabled');
          checkoutButton.setAttribute('aria-disabled', 'true');
          // Add a message adjacent to the button
          checkoutButton.title =
            window.CPD.cart?.minimumOrderMessage.replace(`[minimumOrderValue]`, minimumOrderValue) ||
            'Minimum order value not met';
          const messageContainer = document.createElement('div');
          messageContainer.className = 'cpd-minimum-order-message';
          messageContainer.style.color = 'red';
          messageContainer.style.marginTop = '10px';
          messageContainer.style.fontSize = 'small';
          messageContainer.textContent =
            window.CPD.cart?.minimumOrderMessage.replace(
              `[minimumOrderValue]`,
              window.CPD.shopify.formatMoney(minimumOrderValue, window.CPD.shop.money_format)
            ) || 'Please add more items to your cart to meet the minimum order value.';
          // Remove any existing message
          const existingMessage = document.querySelector('.cpd-minimum-order-message');
          if (existingMessage) {
            existingMessage.remove();
          }
          // Insert the message after the checkout button
          checkoutButton.parentNode.insertBefore(messageContainer, checkoutButton.nextSibling);
        } else {
          checkoutButton.disabled = false;
          checkoutButton.classList.remove('disabled');
          checkoutButton.removeAttribute('aria-disabled');
          checkoutButton.title = '';
          const messageContainer = document.querySelector('.cpd-minimum-order-message');
          if (messageContainer) {
            messageContainer.remove();
          }
        }
        // Reconnect the observer
        if (window.__checkoutButtonsObserver__) {
          window.__checkoutButtonsObserver__.observe(document.body, { childList: true, subtree: true });
        }
      });
    }
  }

  // Run initially
  updateCheckoutButtons();

  if (window.CPD.shopify.isCartPage()) {
    setTimeout(() => {
      // Wait for the cart to load
      document.querySelectorAll("[name='checkout'], [href*='/checkout'],.button-checkout").forEach((b) => {
        if (b.type === 'hidden') return;
        if (b.classList.contains('cpd-checkout-button')) return;
        const clonedButton = b.cloneNode(true);
        clonedButton.id = 'cpd-checkout-button';
        clonedButton.type = 'button';

        clonedButton.classList.add('cpd-checkout-button');
        b.replaceWith(clonedButton);
      });
    }, 1000);
  }

  // Set up a MutationObserver to watch for new elements
  window.__checkoutButtonsObserver__ = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'childList') {
        updateCheckoutButtons();
      }
    });
  });

  // Start observing the document with the configured parameters
  window.__checkoutButtonsObserver__.observe(document.body, { childList: true, subtree: true });
</script>


  
    
    
    

    

    
      
        
        
          
          
        
          
          
        
      
    

    
